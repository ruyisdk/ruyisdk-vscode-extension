{
  "name": "ruyisdk-vscode-extension",
  "displayName": "RuyiSDK",
  "description": "VS Code integration for the Ruyi package manager.",
  "version": "0.1.3-beta.1",
  "publisher": "RuyiSDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruyisdk/ruyisdk-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/ruyisdk/ruyisdk-vscode-extension/issues"
  },
  "homepage": "https://github.com/ruyisdk/ruyisdk-vscode-extension#readme",
  "engines": {
    "vscode": "^1.88.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "ruyi",
    "ruyisdk",
    "risc-v",
    "riscv",
    "toolchain",
    "package manager",
    "virtual environment",
    "sdk"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "walkthroughs": [
      {
        "id": "ruyi.welcome",
        "title": "%contributes.walkthroughs.ruyi.welcome.title%",
        "description": "%contributes.walkthroughs.ruyi.welcome.description%",
        "steps": [
          {
            "id": "install",
            "title": "%contributes.walkthroughs.ruyi.welcome.steps.install.title%",
            "description": "%contributes.walkthroughs.ruyi.welcome.steps.install.description%",
            "completionEvents": [
              "onContext:ruyi.tutorial.installationComplete"
            ],
            "media": {
              "markdown": "media/install.md"
            }
          },
          {
            "id": "packages",
            "title": "%contributes.walkthroughs.ruyi.welcome.steps.packages.title%",
            "description": "%contributes.walkthroughs.ruyi.welcome.steps.packages.description%",
            "completionEvents": [
              "onView:ruyiPackagesView"
            ],
            "media": {
              "image": "media/packages.png",
              "altText": "%contributes.walkthroughs.ruyi.welcome.steps.packages.media.altText%"
            }
          },
          {
            "id": "venv",
            "title": "%contributes.walkthroughs.ruyi.welcome.steps.venv.title%",
            "description": "%contributes.walkthroughs.ruyi.welcome.steps.venv.description%",
            "completionEvents": [
              "onCommand:ruyi.venv.create"
            ],
            "media": {
              "image": "media/create-venv.png",
              "altText": "%contributes.walkthroughs.ruyi.welcome.steps.venv.media.altText%"
            }
          },
          {
            "id": "activate",
            "title": "%contributes.walkthroughs.ruyi.welcome.steps.activate.title%",
            "description": "%contributes.walkthroughs.ruyi.welcome.steps.activate.description%",
            "completionEvents": [
              "onCommand:ruyi.venv.activate"
            ],
            "media": {
              "image": "media/activate-venv.png",
              "altText": "%contributes.walkthroughs.ruyi.welcome.steps.activate.media.altText%"
            }
          },
          {
            "id": "news",
            "title": "%contributes.walkthroughs.ruyi.welcome.steps.news.title%",
            "description": "%contributes.walkthroughs.ruyi.welcome.steps.news.description%",
            "completionEvents": [
              "onCommand:ruyi.news.showCards"
            ],
            "media": {
              "image": "media/news.png",
              "altText": "%contributes.walkthroughs.ruyi.welcome.steps.news.media.altText%"
            }
          },
          {
            "id": "example",
            "title": "%contributes.walkthroughs.ruyi.welcome.steps.example.title%",
            "description": "%contributes.walkthroughs.ruyi.welcome.steps.example.description%",
            "media": {
              "image": "media/example.png",
              "altText": "%contributes.walkthroughs.ruyi.welcome.steps.example.media.altText%"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ruyi",
          "title": "Ruyi",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "ruyi": [
        {
          "id": "ruyiPackagesView",
          "name": "%contributes.views.ruyiPackagesView.name%",
          "icon": "$(package)"
        },
        {
          "id": "ruyiVenvsView",
          "name": "%contributes.views.ruyiVenvsView.name%",
          "icon": "$(server-process)"
        }
      ]
    },
    "commands": [
      {
        "command": "ruyi.board-docs",
        "title": "%contributes.commands.ruyi.board-docs.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.setup.detect",
        "title": "%contributes.commands.ruyi.setup.detect.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.setup.install",
        "title": "%contributes.commands.ruyi.setup.install.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.setup.update",
        "title": "%contributes.commands.ruyi.setup.update.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.setup.manage",
        "title": "%contributes.commands.ruyi.setup.manage.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.home.show",
        "title": "%contributes.commands.ruyi.home.show.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.news.search",
        "title": "%contributes.commands.ruyi.news.search.title%",
        "category": "Ruyi",
        "icon": "$(search)"
      },
      {
        "command": "ruyi.news.clearSearch",
        "title": "%contributes.commands.ruyi.news.clearSearch.title%",
        "category": "Ruyi",
        "icon": "$(clear-all)"
      },
      {
        "command": "ruyi.news.showCards",
        "title": "%contributes.commands.ruyi.news.showCards.title%",
        "category": "Ruyi",
        "icon": "$(layout)"
      },
      {
        "command": "ruyi.packages.search",
        "title": "%contributes.commands.ruyi.packages.search.title%",
        "category": "Ruyi",
        "icon": "$(search)"
      },
      {
        "command": "ruyi.packages.clearSearch",
        "title": "%contributes.commands.ruyi.packages.clearSearch.title%",
        "category": "Ruyi",
        "icon": "$(clear-all)"
      },
      {
        "command": "ruyi.packages.install",
        "title": "%contributes.commands.ruyi.packages.install.title%",
        "category": "Ruyi",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ruyi.packages.uninstall",
        "title": "%contributes.commands.ruyi.packages.uninstall.title%",
        "category": "Ruyi",
        "icon": "$(trash)"
      },
      {
        "command": "ruyi.packages.refresh",
        "title": "%contributes.commands.ruyi.packages.refresh.title%",
        "category": "Ruyi",
        "icon": "$(refresh)"
      },
      {
        "command": "ruyi.venv.refresh",
        "title": "%contributes.commands.ruyi.venv.refresh.title%",
        "category": "Ruyi",
        "icon": "$(refresh)"
      },
      {
        "command": "ruyi.venv.create",
        "title": "%contributes.commands.ruyi.venv.create.title%",
        "category": "Ruyi",
        "icon": "$(plus)"
      },
      {
        "command": "ruyi.venv.clean",
        "title": "%contributes.commands.ruyi.venv.clean.title%",
        "category": "Ruyi",
        "icon": "$(trash)"
      },
      {
        "command": "ruyi.venv.activate",
        "title": "%contributes.commands.ruyi.venv.activate.title%",
        "category": "Ruyi",
        "icon": "$(check)"
      },
      {
        "command": "ruyi.venv.deactivate",
        "title": "%contributes.commands.ruyi.venv.deactivate.title%",
        "category": "Ruyi",
        "icon": "$(close)"
      },
      {
        "command": "ruyi.extract",
        "title": "%contributes.commands.ruyi.extract.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.telemetry.configure",
        "title": "%contributes.commands.ruyi.telemetry.configure.title%",
        "category": "Ruyi"
      },
      {
        "command": "ruyi.build.run",
        "title": "%contributes.commands.ruyi.build.run.title%",
        "category": "Ruyi",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ruyi.packages.search",
          "when": "view == ruyiPackagesView",
          "group": "navigation@0"
        },
        {
          "command": "ruyi.packages.clearSearch",
          "when": "view == ruyiPackagesView",
          "group": "navigation@1"
        },
        {
          "command": "ruyi.packages.refresh",
          "when": "view == ruyiPackagesView",
          "group": "navigation@2"
        },
        {
          "command": "ruyi.venv.refresh",
          "when": "view == ruyiVenvsView",
          "group": "navigation@0"
        },
        {
          "command": "ruyi.venv.create",
          "when": "view == ruyiVenvsView",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "ruyi.packages.install",
          "when": "view == ruyiPackagesView && viewItem == ruyiPackage.available",
          "group": "inline@1"
        },
        {
          "command": "ruyi.packages.uninstall",
          "when": "view == ruyiPackagesView && viewItem == ruyiPackage.installed",
          "group": "inline@1"
        },
        {
          "command": "ruyi.venv.activate",
          "when": "view == ruyiVenvsView && viewItem == ruyiVenv.itemNonCurrent",
          "group": "inline@1"
        },
        {
          "command": "ruyi.venv.deactivate",
          "when": "view == ruyiVenvsView && viewItem == ruyiVenv.current",
          "group": "inline@1"
        },
        {
          "command": "ruyi.venv.clean",
          "when": "view == ruyiVenvsView && viewItem == ruyiVenv.itemNonCurrent",
          "group": "inline@2"
        }
      ],
      "editor/title": [
        {
          "command": "ruyi.build.run",
          "group": "navigation@0"
        }
      ],
      "commandPalette": [
        {
          "command": "ruyi.packages.install",
          "when": "false"
        },
        {
          "command": "ruyi.packages.uninstall",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "ruyi.extract",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Ruyi SDK",
      "properties": {
        "ruyi.checkForUpdates": {
          "type": "boolean",
          "default": true,
          "description": "%contributes.configuration.properties.ruyi.checkForUpdates.description%"
        },
        "ruyi.ruyiPath": {
          "type": "string",
          "default": "",
          "description": "%contributes.configuration.properties.ruyi.ruyiPath.description%"
        },
        "ruyi.telemetry": {
          "type": "boolean",
          "description": "%contributes.configuration.properties.ruyi.telemetry.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "release": "bumpp --all --no-commit --no-tag --no-push",
    "package": "vsce package"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.4.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.88.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "bumpp": "^10.3.2",
    "changelogithub": "^14.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vsxpub": "^0.1.2"
  },
  "dependencies": {
    "semver": "^7.7.3"
  }
}
